<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>NSPrivacyTracking</key>
	<false/>
	<key>NSPrivacyTrackingDomains</key>
	<array/>
	<!--
	  Relay collects no data — see docs/legal/privacy-policy.md. This array stays empty unless that
	  changes (e.g. the currently-unused opt-in analytics setting is ever wired to a real collector).
	-->
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<!--
			  AppSettings/UITestSupport read and write UserDefaults.standard for local, on-device
			  preferences only (no App Group, no iCloud/NSUbiquitousKeyValueStore) -- reason 1C8F.1
			  ("access info from same app, per device for this app") is the accurate declaration.
			-->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>1C8F.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
